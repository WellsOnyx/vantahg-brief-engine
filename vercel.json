{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "redirects": [
    { "source": "/", "destination": "/demo-tour", "permanent": false }
  ],
  "crons": [
    {
      "path": "/api/cron/sla-check",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/efax-process",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/meow-invoice-sync",
      "schedule": "*/30 * * * *"
    }
  ]
}
