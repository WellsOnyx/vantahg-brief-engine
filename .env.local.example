# VantaUM Clinical Brief Engine — Environment Variables
# Copy to .env.local and fill in values

# Supabase (required for production, omit for demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (required for AI brief generation)
ANTHROPIC_API_KEY=

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Webhook Security
WEBHOOK_SECRET=

# External API Key (for /api/external/submit)
VANTAHG_API_KEY=

# SMTP Email (nodemailer — works with SendGrid, Resend, SES, Mailgun, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=VantaUM <noreply@vantaum.com>

# Admin notifications (SLA escalations, system alerts)
ADMIN_NOTIFICATION_EMAIL=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Application URL (for links in emails)
NEXTAUTH_URL=https://app.vantaum.com

# Credential encryption key (32-byte hex string for AES-256-GCM)
CREDENTIAL_ENCRYPTION_KEY=
