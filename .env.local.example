# VantaUM Clinical Brief Engine — Environment Variables
# Copy to .env.local and fill in values

# Supabase (required for production, omit for demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (required for AI brief generation)
ANTHROPIC_API_KEY=

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Webhook Security
WEBHOOK_SECRET=

# External API Key (for /api/external/submit)
VANTAHG_API_KEY=

# SMTP Email (nodemailer — works with SendGrid, Resend, SES, Mailgun, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=VantaUM <noreply@vantaum.com>

# Admin notifications (SLA escalations, system alerts)
ADMIN_NOTIFICATION_EMAIL=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Application URL (for links in emails)
NEXTAUTH_URL=https://app.vantaum.com

# Credential encryption key (32-byte hex string for AES-256-GCM)
CREDENTIAL_ENCRYPTION_KEY=

# ── Gravity Rail ──────────────────────────────────────────────────────────────
# Sign up at https://app.gravityrail.com/get-started (PAYG, credit card required)
# API key docs: https://docs.gravityrail.com/developer/guides/authentication#creating-an-api-key

# Server-side only (never expose to browser)
GRAVITY_RAIL_API_KEY=

# Default workspace UUID — shown in your GR dashboard URL
GRAVITY_RAIL_WORKSPACE_ID=

# Demo preview password protection (set in Vercel → Settings → Environment Variables)
# Only share this with people you want to see the exclusive demo.
DEMO_PASSWORD=

# Client-side (safe to expose — these are public identifiers, not secrets)
NEXT_PUBLIC_GRAVITY_RAIL_WORKSPACE_ID=
NEXT_PUBLIC_GRAVITY_RAIL_SITE_ID=
NEXT_PUBLIC_GRAVITY_RAIL_WORKFLOW_SLUG=member-support

# ── Dropbox Sign (formerly HelloSign) ─────────────────────────────────────────
# API key from https://app.hellosign.com/home/myAccount#api
# Client ID (App ID) from the same page — required for webhook signature verification.
# Sign requests run in Dropbox-Sign test mode automatically when NODE_ENV != production.
# Set ENABLE_REAL_HELLOSIGN=true to actually hit the API (otherwise demo stub returns).
HELLOSIGN_API_KEY=
HELLOSIGN_CLIENT_ID=
ENABLE_REAL_HELLOSIGN=false

# --- Canonical Intake Contract v1.1 (docs/INTAKE_CONTRACT.md) ---
# HMAC secret Gravity Rail signs intake webhooks with (canonical name).
GR_WEBHOOK_SECRET=
# Second active secret during rotation (both validate; clear when done).
GR_WEBHOOK_SECRET_SECONDARY=
# MVP environment ONLY - enables the X-GR-Sandbox verification path.
# Never set in production.
INTAKE_SANDBOX_ENABLED=

# --- Throughput: brief-generation queue (migration 034) ---
# Move AI brief generation off the intake request path onto the worker.
ENABLE_BRIEF_QUEUE=false
BRIEF_WORKER_BATCH_SIZE=20
BRIEF_WORKER_CONCURRENCY=4
