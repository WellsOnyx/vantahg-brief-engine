# VantaUM Clinical Brief Engine — Environment Variables
# Copy to .env.local and fill in values

# Supabase (required for production, omit for demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (required for AI brief generation)
ANTHROPIC_API_KEY=

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Webhook Security
WEBHOOK_SECRET=

# External API Key (for /api/external/submit)
VANTAHG_API_KEY=

# SMTP Email (nodemailer — works with SendGrid, Resend, SES, Mailgun, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=VantaUM <noreply@vantaum.com>

# Admin notifications (SLA escalations, system alerts)
ADMIN_NOTIFICATION_EMAIL=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Application URL (for links in emails)
NEXTAUTH_URL=https://app.vantaum.com

# Credential encryption key (32-byte hex string for AES-256-GCM)
CREDENTIAL_ENCRYPTION_KEY=

# ── Gravity Rail ──────────────────────────────────────────────────────────────
# Sign up at https://app.gravityrail.com/get-started (PAYG, credit card required)
# API key docs: https://docs.gravityrail.com/developer/guides/authentication#creating-an-api-key

# Server-side only (never expose to browser)
GRAVITY_RAIL_API_KEY=

# Default workspace UUID — shown in your GR dashboard URL
GRAVITY_RAIL_WORKSPACE_ID=

# Client-side (safe to expose — these are public identifiers, not secrets)
NEXT_PUBLIC_GRAVITY_RAIL_WORKSPACE_ID=
NEXT_PUBLIC_GRAVITY_RAIL_SITE_ID=
NEXT_PUBLIC_GRAVITY_RAIL_WORKFLOW_SLUG=member-support

# ── First Mover ──────────────────────────────────────────────────────
# Set RELEASE_TRACK=firstmover on the deploy to expose /firstmover/* routes.
# Main deploy leaves this unset and serves a 404 on /firstmover.
RELEASE_TRACK=

# Hard gate on real PHI in the First Mover namespace. Default unset (false) —
# server only operates on synthetic data flows even when Supabase is wired.
# Flip to 'true' only after Supabase + Anthropic BAAs are signed AND MFA is
# added on top of the magic-link auth.
FIRSTMOVER_ALLOW_PHI=

# ── First Mover · Gravity Rails AI overflow ──────────────────────────
# Drop in your GR account credentials and the overflow agent activates.
# Visit /firstmover/admin/gravity-rails to verify all checks pass.

# Bearer key the GR agent uses to call our tool endpoints.
# Reuses the existing VANTAHG_API_KEY above (so set that first).

# Webhook signing secret — must match what you configure in your GR
# workflow's webhook settings. HMAC-SHA256, header X-GR-Signature.
GRAVITY_RAIL_WEBHOOK_SECRET=

# Overflow trigger mode: off | always | after_hours | (unset = manual toggle)
# - off: agent never takes intake
# - always: agent handles all intake (load testing / demos)
# - after_hours: agent runs outside FIRSTMOVER_BUSINESS_HOURS in the configured tz
# - unset: manual toggle from /firstmover/admin/gravity-rails
FIRSTMOVER_AGENT_OVERFLOW=

# Business hours for after_hours mode (default 9-17 ET, M-F).
FIRSTMOVER_BUSINESS_HOURS_TZ=America/New_York
FIRSTMOVER_BUSINESS_HOURS=9-17
