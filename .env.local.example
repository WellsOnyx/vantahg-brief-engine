# VantaUM Clinical Brief Engine — Environment Variables
# Copy to .env.local and fill in values

# Supabase (required for production, omit for demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (required for AI brief generation)
ANTHROPIC_API_KEY=

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Webhook Security
WEBHOOK_SECRET=

# External API Key (for /api/external/submit)
VANTAHG_API_KEY=

# eFax Pipeline — Phaxio (required for production eFax intake)
PHAXIO_CALLBACK_TOKEN=
PHAXIO_API_KEY=
PHAXIO_API_SECRET=

# eFax Pipeline — Google Cloud Vision OCR
GOOGLE_VISION_API_KEY=

# Cron Secret (generate with: openssl rand -hex 32)
CRON_SECRET=
